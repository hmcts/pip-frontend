{
    "exclude": ["src/test/e2e/**/*.ts"],
    "compilerOptions": {
        "outDir": "./dist/",
        "module": "commonjs",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "target": "es6",
        "noImplicitAny": false,
        "moduleResolution": "bundler",
        "noUnusedLocals": true,
        "resolveJsonModule": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "lib": ["es6", "es2017.object", "dom"],
        "strict": false,
        "types": ["node","jest"],
        "rootDir": ".",
        "paths": {
            "*": ["./src/main/*"],
            "router/*": ["./router/*"],
            "routes/*": ["./routes/*"]
        },
        "typeRoots": ["./node_modules/@types"]
    }
}
