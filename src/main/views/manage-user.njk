{% extends "template.njk" %}
{% from "./macros/common-components.njk" import goBack %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}

{% block pageTitle %}
  {{ title }}
{% endblock %}
{% block beforeContent %}
  {{ super() }}
  {{ goBack() }}
{% endblock %}
{% block content %}
  <div class="parent-box">
    <h1 class="govuk-heading-l">Manage {{ userData.email }}</h1>
    {{ govukWarningText({
      text: "Ensure authorisation has been granted before updating this user. Every action is monitored.",
      iconFallbackText: "Warning"
    }) }}
    {{ govukSummaryList({
      rows: [

        {
          key: {
          text: "User ID"
        },
          value: {
          text: userData.userId
        },
          actions: {

        }
        },
        {
          key: {
          text: "Email"
        },
          value: {
          text: userData.email
        },
          actions: {
        }
        },

        {
          key: {
          text: "Role"
        },
          value: {
          html: userData.roles
        },
          actions: {
          items: [
            {
              href: "#",
              text: "Change",
              visuallyHiddenText: "roles"
            }
          ]
        }
        },
        {
          key: {
          text: "Provenance"
        },
          value: {
          html: userData.userProvenance
        },
          actions: {
        }
        },
        {
          key: {
          text: "Provenance ID"
        },
          value: {
          html: userData.provenanceUserId
        },
          actions: {
        }
        },
        {
          key: {
          text: "Creation Date"
        },
          value: {
          html: creationDate
        },
          actions: {
        }
        },
        {
          key: {
          text: "Last Sign In"
        },
          value: {
          html: lastSignIn
        },
          actions: {
        }
        }
      ]
    }) }}

    {{ govukButton({
      text: "Delete user",
      classes: "govuk-button--warning",
      href: hrefDeletion
    }) }}

  </div>
{% endblock %}
{% block bodyEnd %}
  {{ super() }}
{% endblock %}
